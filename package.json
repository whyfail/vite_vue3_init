    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "autoprefixer": "^10.5.0",
    "code-inspector-plugin": "^1.5.4",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.7",
    "shadcn-vue": "^2.7.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
