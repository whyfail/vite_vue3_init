{
  "name": "{{ name }}",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "description": "{{ description }}",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/start.js",
