{
  "name": "{{ name }}",
  "version": "1.0.0",
  "private": true,
  "description": "{{ description }}",
  "type": "module",
  "scripts": {
    "dev": "node scripts/start.js",
    "build": "node scripts/build.js",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=junit --outputFile=test-results/vitest-junit.xml",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:component-coverage": "node scripts/check-component-tests.js",
    "lint": "oxlint . --vue-plugin --import-plugin --deny-warnings",
    "lint:fix": "oxlint . --vue-plugin --import-plugin --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@heroicons/vue": "^2.2.0",
    "@lucide/vue": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ogl": "^1.0.11",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@plugin-web-update-notification/vite": "^2.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^26.1.0",
    "@vitejs/devtools": "^0.3.4",
    "@vitejs/devtools-kit": "^0.3.4",
    "@vitejs/devtools-self-inspect": "^0.3.4",
    "@vitejs/plugin-legacy": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.2",
    "code-inspector-plugin": "^1.6.5",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "shadcn-vue": "^2.7.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "node scripts/verify-commit.js $1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": "oxlint --vue-plugin --import-plugin --fix --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,vue,json,jsonc,css,html,md,yml,yaml}": "oxfmt --write --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@11.10.0"
}
